<nav class="glass-navbar px-3 py-2 d-flex align-items-center w-100">
  <div class="d-flex align-items-center gap-2">
    <%= image_tag "logo.png", class: "app-logo" %>
    <div class="fw-bold text-white">Password Manager</div>
  </div>

  <div class="ms-auto d-flex align-items-center gap-3">
    <% if current_user %>
      <div class="dropdown-user"><%= current_user.name.upcase %></div>

      <div class="profile-dropdown">
        <div class="profile-icon" onclick="toggleMenu()"><%= current_user.name.first.upcase %></div>
        <div class="dropdown-menu" id="profileMenu">
          <div class="dropdown-user"><%= current_user.name %></div>
          <div class="dropdown-user"><%= current_user.email %></div>

          <%= button_to "⚙️ Settings",
           settings_path, 
           method: :get,
           class: "dropdown-item" %>

          <%= button_to "🚪 Sign Out",
            logout_path,
            method: :delete,
            class: "dropdown-item danger-btn" %>
        </div>
      </div>
    <% end %>
  </div>
</nav>
