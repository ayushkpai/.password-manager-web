<aside class="sidebar">
  <nav class="nav">
    <%= link_to "🏠 Home",
      root_path,
      class: "nav-link #{'active-nav' if current_page?(root_path)}" %>

    <% if current_user %>
      <%= link_to "🔑 Passwords",
        passwords_path,
        class: "nav-link #{'active-nav' if current_page?(passwords_path)}" %>

      <%= link_to "⚙️ Settings",
        settings_path,
        class: "nav-link #{'active-nav' if current_page?(settings_path)}" %>

      <hr class="divider">

      <%= link_to "➕ Add Password", "#",
        data: { bs_toggle: "modal", bs_target: "#addPasswordModal" } %>
    <% end %>

      <%= link_to "📄 Privacy Policy", "#",
        class: "nav-link",
        data: { bs_toggle: "offcanvas", bs_target: "#privacyOffcanvas" } %>

    <% if current_user %>
      <%= link_to "📘 How to use", "#",
        class: "nav-link",
        data: { bs_toggle: "offcanvas", bs_target: "#helpOffcanvas" } %>

      <%= link_to "ℹ️ About Us", "#",
        class: "nav-link",
        data: { bs_toggle: "offcanvas", bs_target: "#aboutOffcanvas" } %>
    <% else %>
      <%= link_to "Sign In",
        login_path,
        class: "nav-link #{'active-nav' if current_page?(login_path)}" %>

      <%= link_to "Sign Up",
        signup_path,
        class: "nav-link #{'active-nav' if current_page?(signup_path)}" %>
    <% end %>
  </nav>

  <% if current_user %>
    <div class="sidebar-bottom">
      <%= button_to "🚪 Sign Out",
        logout_path,
        method: :delete,
        class: "dropdown-item danger-btn" %>
    </div>
  <% end %>
</aside>
