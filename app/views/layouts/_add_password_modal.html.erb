<div class="modal fade" id="addPasswordModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add Password</h5>
        <button
          type="button"
          class="btn-close btn-close-white"
          data-bs-dismiss="modal"
          aria-label="Close">
        </button>
      </div>
        <div class="modal-body">

          <%= form_with model: Password.new, url: passwords_path do |f| %>

            <div class="mb-3">
              <%= f.label :app %>
              <%= f.text_field :app, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= f.label :password %>
              <%= f.text_field :password, class: "form-control" %>
            </div>

            <%= f.submit "Add", class: "btn btn-success w-100" %>
          <% end %>
        </div>
    </div>
  </div>
</div>
