<div class="offcanvas offcanvas-end glass-offcanvas"
  tabindex="-1"
  id="helpOffcanvas">

  <div class="offcanvas-header glass-offcanvas-header">
    <h5 class="offcanvas-title">How to use</h5>

    <button type="button"
      class="btn-close btn-close-white"
      data-bs-dismiss="offcanvas"></button>
  </div>

  <div class="offcanvas-body">
    <div class="glass-section">
      <h6>🔑 Add Password</h6>
      <p>
        Click <b>“Add Password”</b> in the sidebar to store a new login securely.
        Fill in the website, username, and password, then save it
      </p>
    </div>

    <div class="glass-section">
      <h6>📋 Copy Password</h6>
      <p>
        Each saved password has a copy button.
        Click it to instantly copy the password to your clipboard
      </p>
    </div>

    <div class="glass-section">
      <h6>🔍 Search</h6>
      <p>
        Use the search bar to quickly find saved accounts by website or username
      </p>
    </div>

    <div class="glass-section">
      <h6>⚙️ Settings</h6>
      <p>
        Manage your account settings like email or preferences from the Settings page
      </p>
    </div>

    <div class="glass-section">
      <h6>🚪 Logout</h6>
      <p>
        Click the Sign Out button at the bottom of the sidebar to securely log out
      </p>
    </div>
  </div>
</div>
