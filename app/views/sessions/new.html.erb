<div class="login-container">
  <h1>Login</h1>

  <p>Don't have an account <%= link_to "Sign Up", signup_path %></p>

  <%= form_with url: login_path, class: "login-form" do |f| %>
    <%= f.label :email %>
    <%= f.email_field :email, autofocus: true %>

    <%= f.label :password %>
    <%= f.password_field :password %>

    <%= f.submit "Sign In" %>
  <% end %>
</div>
