<% content_for :title, "Passwords"  %>

<div class="liquid-title">
  <h1>Passwords</h1>
</div>

<div class="spotlight-wrapper">
  <input
    type="text"
    id="search"
    placeholder="Search passwords..."
    onkeyup="filterPasswords()"
    class="spotlight-input"
    autofocus
  />
</div>

<div class="password-list">

  <% @passwords.each do |p| %>
    <section class="password">

      <h2><%= p.app %></h2>

      <div class="password-row">

        <div
          class="password-value"
          data-password="<%= p.password %>"
          onmousedown="reveal(this)"
          onmouseup="hide(this)"
          onmouseleave="hide(this)">
          ••••••••••••
        </div>

        <button
          class="copy-text-btn"
          onclick="copyPassword('<%= j p.password %>', this)">
          Copy
        </button>
      </div>

      <div class="actions">
      <%= link_to "Edit",
          edit_password_path(p),
          class: "glass-btn" %>

      <%= button_to "Delete",
          password_path(p),
          method: :delete,
          data: { confirm: "Delete this password?" },
          class: "glass-btn glass-btn-danger" %>
    </div>

    </section>
  <% end %>

</div>

<script>
  const hideTimers = new WeakMap();

  function reveal(el) {
    if (hideTimers.has(el)) {
      clearTimeout(hideTimers.get(el));
    }

    el.innerText = el.dataset.password;

    const timer = setTimeout(() => {
      hide(el);
    }, 15000);

    hideTimers.set(el, timer);
  }

  function hide(el) {
    el.innerText = "••••••••••••";
  }

  function copyPassword(password, button) {
    navigator.clipboard.writeText(password);

    button.classList.add("copied");

    setTimeout(() => {
      button.classList.remove("copied");
    }, 1200);
  }

  function filterPasswords() {
    const query = document.getElementById("search").value.toLowerCase();

    document.querySelectorAll(".password").forEach(card => {
      const app = card.querySelector("h2").innerText.toLowerCase();
      card.style.display = app.includes(query) ? "block" : "none";
    });
  }

  document.addEventListener("visibilitychange", () => {
    if (document.hidden) {
      document.querySelectorAll(".password-value").forEach(el => {
        hide(el);
      });
    }
  });
</script>
